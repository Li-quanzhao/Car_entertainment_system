# Car Agent Server — 环境配置示例
# 复制为 .env 并按需修改

# HTTP Server
AGENT_HOST=0.0.0.0
AGENT_PORT=8000

# gRPC Server
GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# LLM 配置（使用 DeepSeek 或 OpenAI 兼容 API）
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# 本地模型（降级方案）
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# 生产部署鉴权（可选，设置后 HMI 请求需携带 X-API-Key 头）
# API_AUTH_KEY=your_secret_key_here

# 会话历史
MAX_HISTORY_TURNS=10
